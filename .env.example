# ---- Required ----

# The "Publish to web" CSV link for your Cookbook catalogue sheet.
# In Google Sheets: File > Share > Publish to web > (select the sheet) > Comma-separated values (.csv) > Publish.
# Paste the resulting URL here. It should look like:
# https://docs.google.com/spreadsheets/d/e/<LONG_ID>/pub?gid=0&single=true&output=csv
SHEET_CSV_URL=

# Your Anthropic API key (https://console.anthropic.com/).
# Required for natural-language search. Without it, the app falls back to basic keyword search.
# The app also accepts the names CLAUDE_API_KEY or claude_api_key if you prefer.
ANTHROPIC_API_KEY=

# ---- Optional ----

# Which Claude model to use for query understanding + ranking.
# Defaults to claude-haiku-4-5 (fast + low cost). Bump to claude-sonnet-4-6 or
# claude-opus-4-8 for higher-quality understanding at higher cost.
ANTHROPIC_MODEL=claude-haiku-4-5

# How long (seconds) to cache the sheet data in memory before re-fetching.
# Lower = your edits show up faster; higher = fewer fetches. Default 300 (5 min).
SHEET_CACHE_TTL_SECONDS=300

# ---- Optional: find-recipe-links script ----
# Used by:  node scripts/find-recipe-links.mjs
# Searches the web for each recipe without a link, has Claude verify the result
# is genuinely that cookbook's recipe, and writes the URL back to the sheet.
# Also uses ANTHROPIC_API_KEY (above) for the verification step, plus the
# write-back service account below.
#
# Pick ONE search provider:
#
# A) Serper.dev (recommended — simplest). Sign up at https://serper.dev and copy
#    your API key. Free signup includes 2,500 one-time search credits.
SERPER_API_KEY=
#
# B) Google Custom Search (fallback, more setup). Used only if SERPER_API_KEY is blank.
#    1. console.cloud.google.com → enable "Custom Search API" → Credentials → Create API key
GOOGLE_CSE_API_KEY=
#    2. programmablesearchengine.google.com → New search engine → create → copy the Search engine ID
GOOGLE_CSE_CX=

# ---- Optional: write-back (set verdicts / prep notes from the app, or used by find-recipe-links) ----
# Leave blank to keep the app read-only. To enable, create a Google Cloud
# service account, enable the Google Sheets API, share your sheet with the
# service account email as an Editor, then set all four:
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# The spreadsheet ID (the long id in the sheet's URL):
SHEET_ID=
# The exact name of the recipe tab (e.g. Sheet1):
SHEET_TAB_NAME=
