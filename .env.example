# ---- Required ----

# The "Publish to web" CSV link for your Cookbook catalogue sheet.
# In Google Sheets: File > Share > Publish to web > (select the sheet) > Comma-separated values (.csv) > Publish.
# Paste the resulting URL here. It should look like:
# https://docs.google.com/spreadsheets/d/e/<LONG_ID>/pub?gid=0&single=true&output=csv
SHEET_CSV_URL=

# Your Anthropic API key (https://console.anthropic.com/).
# Required for natural-language search. Without it, the app falls back to basic keyword search.
# The app also accepts the names CLAUDE_API_KEY or claude_api_key if you prefer.
ANTHROPIC_API_KEY=

# ---- Security (required to access the app) ----

# The password you'll type to unlock the app.
APP_PASSWORD=

# A long random string used to sign login sessions. Must be >= 16 chars.
# Generate one with:  openssl rand -base64 32
# If APP_PASSWORD or SESSION_SECRET is missing, the app fails closed (no access).
SESSION_SECRET=

# ---- Optional ----

# Which Claude model to use for query understanding + ranking.
# Defaults to claude-haiku-4-5 (fast + low cost). Bump to claude-sonnet-4-6 or
# claude-opus-4-8 for higher-quality understanding at higher cost.
ANTHROPIC_MODEL=claude-haiku-4-5

# How long (seconds) to cache the sheet data in memory before re-fetching.
# Lower = your edits show up faster; higher = fewer fetches. Default 300 (5 min).
SHEET_CACHE_TTL_SECONDS=300

# ---- Optional: write-back (set verdicts / prep notes from the app) ----
# Leave blank to keep the app read-only. To enable, create a Google Cloud
# service account, enable the Google Sheets API, share your sheet with the
# service account email as an Editor, then set all four:
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# The spreadsheet ID (the long id in the sheet's URL):
SHEET_ID=
# The exact name of the recipe tab (e.g. Sheet1):
SHEET_TAB_NAME=

# ---- Optional: find-recipe-urls script (scan trusted sites for recipe links) ----
# `npm run find-urls` scans a curated allowlist of reputable recipe sites for the
# online version of each un-linked recipe and writes matches back to your sheet.
# It needs ANTHROPIC_API_KEY (with web search enabled on the account) and the same
# four Google service-account vars above (it reads and writes via the Sheets API).
#
# Which column to write found URLs into. Leave blank to reuse your existing
# "Recipe link" column; set it to a header to use/create a dedicated column.
RECIPE_URL_COLUMN=
# The script benefits from a stronger model for judging matches; it defaults to
# claude-sonnet-4-6 (override with ANTHROPIC_MODEL above).
